package message

import bait.token

// Message kind
pub enum Kind {
	info
	warning
	error
}

// Source that reported the message
pub enum Reporter {
	general
	builder
	lexer
	parser
	checker
	gen
}

pub struct Message{
	pub kind Kind

	pub title string
	pub details string

	pub path string
	pub pos token.Pos
}
