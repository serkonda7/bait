import cli.options

fun test_opt_parser() {
	args := ['-s', 'str', '_', '--flag', '-n', '123', 'other', '--f_val', '1.23']
	mut op := options.new_option_parser(args)

	s := op.string('string', `s`, '')
	assert s == 'str'

	b := op.bool('flag', `f`, false)
	assert b == true

	i := op.int('num', `n`, 0)
	assert i == 123

	f := op.float('f_val', `f`, 0.0)
	assert f == 1.23

	assert op.remaining() == ['_', 'other']

	assert op.string('def', ``, 'default') == 'default'
	assert op.float('def', ``, 4.56) == 4.56

	assert args.length == 9
}

fun test_value_opt_does_not_eat_flag() {
	args := ['-n', '--flag', '--bar', '-s']
	mut op := options.new_option_parser(args)

	n := op.int('num', `n`, 42)
	assert n == 42

	b := op.bool('flag', `f`, false)
	assert b == true

	assert op.string('bar', `b`, '') == ''
}

fun test_quoted_string_value() {
	args := ['--eggs', '"--str"', '--ham', "'--str'"]
	mut op := options.new_option_parser(args)

	assert op.string('eggs', `e`, '') == '--str'
	assert op.string('ham', `h`, '') == '--str'
}

fun test_empty_long_does_not_delete_end_of_options_marker() {
	args := ['--', 'foo']
	mut op := options.new_option_parser(args)

	assert op.bool('', `x`, false) == false
	assert op.string('', `y`, '') == ''

	assert op.remaining() == ['--', 'foo']
}
